<?xml version="1.0" encoding="UTF-8"?>
<!--
    Security configuration for the REST API.

    1. security-constraint: protects /api/secured/* — requires authentication
    2. login-config: BASIC auth (browser shows login dialog, clients send Authorization header)
    3. security-role: declares the roles used by @RolesAllowed

    Note: /api/public/* is NOT in the constraint → accessible without auth.
    Alternatively, @PermitAll on the resource overrides the constraint.
-->
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <!--
        Enable @RolesAllowed on JAX-RS resources.
        Without this, RESTEasy ignores the annotations and only
        the web.xml auth-constraint is checked (which allows both roles).
    -->
    <context-param>
        <param-name>resteasy.role.based.security</param-name>
        <param-value>true</param-value>
    </context-param>

    <!-- Protect /api/secured/* — authentication required -->
    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Secured API</web-resource-name>
            <url-pattern>/api/secured/*</url-pattern>
        </web-resource-collection>
        <auth-constraint>
            <role-name>user</role-name>
            <role-name>admin</role-name>
        </auth-constraint>
    </security-constraint>

    <!-- HTTP Basic Authentication -->
    <login-config>
        <auth-method>BASIC</auth-method>
        <realm-name>Security Demo</realm-name>
    </login-config>

    <!-- Declare roles used in @RolesAllowed -->
    <security-role>
        <role-name>user</role-name>
    </security-role>
    <security-role>
        <role-name>admin</role-name>
    </security-role>
</web-app>
